# TURN Server Configuration
# Optional: Configure your own TURN servers for better reliability in production
# If not provided, the app will use the Open Relay Project's free TURN servers

# TURN server URL (e.g., turn:your-turn-server.com:3478 or turns:your-turn-server.com:5349)
VITE_TURN_URL=
# TURN server username
VITE_TURN_USERNAME=
# TURN server credential/password
VITE_TURN_CREDENTIAL=

# Note: STUN servers are hardcoded and don't require configuration
